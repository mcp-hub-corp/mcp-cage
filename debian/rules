#!/usr/bin/make -f

export DH_VERBOSE = 1
export CGO_ENABLED = 0
export GOFLAGS = -mod=vendor
export GOPATH = $(CURDIR)/.gopath
export GOCACHE = $(CURDIR)/.gocache

VERSION := $(shell dpkg-parsechangelog --show-field Version | sed 's/-.*//')
LDFLAGS := -s -w \
  -X github.com/mcp-hub-corp/mcp-cage/internal/cli.Version=$(VERSION) \
  -X github.com/mcp-hub-corp/mcp-cage/internal/cli.GitCommit=ppa \
  -X github.com/mcp-hub-corp/mcp-cage/internal/cli.BuildDate=$(shell date -u +%Y-%m-%dT%H:%M:%SZ)

%:
	dh $@

override_dh_auto_clean:

override_dh_auto_configure:

override_dh_auto_build:
	go build -ldflags "$(LDFLAGS)" -trimpath -o $(CURDIR)/smcp ./cmd/smcp/

override_dh_auto_test:

override_dh_auto_install:
	install -D -m 0755 $(CURDIR)/smcp $(CURDIR)/debian/smcp/usr/bin/smcp

override_dh_dwz:

override_dh_strip:

override_dh_shlibdeps:
